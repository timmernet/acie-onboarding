generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Peloton {
  id      String  @id @default(cuid())
  naam    String  @unique
  groepen Groep[]
  users   User[]
}

model Groep {
  id         String  @id @default(cuid())
  naam       String
  pelotoonId String
  peloton    Peloton @relation(fields: [pelotoonId], references: [id], onDelete: Cascade)
  users      User[]

  @@unique([naam, pelotoonId])
}

model User {
  id             String     @id @default(cuid())
  naam           String
  email          String     @unique
  pin            String
  rol            String
  pelotoonId     String
  groepId        String?
  aangemeldOp    String
  actief         Boolean    @default(false)
  laatstIngelogd String?
  loginPogingen  Int        @default(0)
  geblokkerdTot  String?
  taken          UserTask[]
  peloton        Peloton    @relation(fields: [pelotoonId], references: [id])
  groep          Groep?     @relation(fields: [groepId], references: [id])
}

model Taak {
  id            String     @id @default(cuid())
  titel         String
  beschrijving  String
  categorie     String
  contactId     String     @default("")
  vereistTaakId String?
  volgorde      Int        @default(0)
  userTaken     UserTask[]
}

model UserTask {
  id           String  @id @default(cuid())
  userId       String
  taakId       String
  voltooid     Boolean @default(false)
  voltooiDatum String?
  opmerking    String?
  nieuw        Boolean @default(false)
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  taak         Taak    @relation(fields: [taakId], references: [id], onDelete: Cascade)

  @@unique([userId, taakId])
}

model Contact {
  id       String @id @default(cuid())
  naam     String
  rang     String
  functie  String
  telefoon String
  email    String
  tags     String @default("[]")
}

model Bestand {
  id           String @id @default(cuid())
  naam         String
  beschrijving String @default("")
  categorie    String @default("")
  bestandsnaam String
  bestandstype String
  grootte      Int
  geuploadOp   String
  geuploadDoor String @default("Onbekend")
  url          String
}

model AuditLog {
  id          String  @id @default(cuid())
  tijdstip    String
  userId      String?
  userNaam    String
  userRol     String
  actie       String
  entiteit    String?
  entiteitId  String?
  details     String  @default("{}")
  ipAdres     String?
}

model PinResetToken {
  token   String  @id
  email   String
  naam    String
  expires BigInt
  used    Boolean @default(false)
}

model AppConfig {
  id                   Int     @id @default(1)
  appNaam              String  @default("Reservisten Onboarding")
  eenheidNaam          String  @default("A-Compagnie · 30e Infanteriebataljon")
  eenheidSubtitel      String  @default("13 Lichte Brigade — Reservisten Onboarding")
  logoUrl              String  @default("")
  primairKleur         String  @default("#3f7a22")
  emailHost            String  @default("")
  emailPort            Int     @default(587)
  emailSecure          Boolean @default(false)
  emailUser            String  @default("")
  emailPass            String  @default("")
  emailFrom            String  @default("")
  emailAdmin           String  @default("")
  naamReservist        String  @default("Reservist")
  naamGroepscommandant String  @default("Groepscommandant")
  naamCommandant       String  @default("Pelotonscommandant")
  naamPeloton          String  @default("Peloton")
  naamGroep            String  @default("Groep")
  browserTitel         String  @default("")
  faviconUrl           String  @default("")
  emailType            String  @default("smtp")
  emailTenantId        String  @default("")
  emailClientId        String  @default("")
  emailClientSecret    String  @default("")
}
