# Email configuratie (kopieer dit bestand naar .env en vul de waarden in)

# SMTP instellingen
EMAIL_HOST=smtp.example.com   # verplicht
EMAIL_PORT=587                # optioneel, standaard 587
EMAIL_SECURE=false            # optioneel, standaard false

# Authenticatie (optioneel bij gebruik van een smarthost)
# EMAIL_USER=noreply@example.com
# EMAIL_PASS=jouw-wachtwoord

# Afzender
EMAIL_FROM="A-Compagnie Onboarding <noreply@example.com>"

# Admin e-mailadres voor nieuwe registratie-notificaties
EMAIL_ADMIN=admin@example.com

# Publieke URL van de applicatie (gebruikt in reset-links)
APP_URL=http://localhost:5173
