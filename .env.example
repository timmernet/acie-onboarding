# ============================================================
# Kopieer dit bestand naar .env en vul de waarden in
# cp .env.example .env
# ============================================================

# Omgeving
NODE_ENV=production

# Database (pad relatief aan server/index.js)
DATABASE_URL="file:../server/data.db"

# JWT — gebruik een lange willekeurige string in productie:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=VERVANG_DIT_MET_EEN_LANGE_WILLEKEURIGE_STRING

# Publieke URL van de applicatie (gebruikt in e-mail reset-links)
APP_URL=https://jouwdomein.nl

# Server poort
PORT=3001

# ---- E-mail (SMTP) ----
# Laat leeg om e-mail te simuleren (output naar console)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Onboarding Portaal <noreply@jouwdomein.nl>"
EMAIL_ADMIN=beheerder@jouwdomein.nl

# ---- E-mail (Exchange Online / Microsoft 365) ----
# Stel emailType in op 'exchange' via de beheerdersportal
# EMAIL_TENANT_ID=
# EMAIL_CLIENT_ID=
# EMAIL_CLIENT_SECRET=
